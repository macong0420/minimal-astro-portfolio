---
import { NAVIGATION } from "../../constants/navigation";
import ThemeToggle from "./ThemeToggle.astro";
const pathname = new URL(Astro.request.url).pathname;

const isActive = (path: string) => {
  if (path === "/") return pathname === "/";
  return pathname.startsWith(path);
};
---

<nav>
  <div class="nav-container">
    <div class="nav-links">
      {
        NAVIGATION.map(({ name, path }) => (
          <a href={path} class={isActive(path) ? "active" : ""}>
            {name}
          </a>
        ))
      }
    </div>
    <ThemeToggle />
  </div>
</nav>

<style>
  nav {
    padding: 1.5rem 1rem;
  }

  .nav-container {
    display: flex;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    justify-content: flex-start;
    align-items: center;
    gap: 2rem;
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
    flex: 1;
  }

  .nav-links a {
    color: var(--text-muted, #666666);
    text-decoration: none;
    font-size: var(--text-base, 1rem);
    font-weight: 500;
    padding: 0.5rem 0.75rem;
    border-radius: var(--radius-md, 0.375rem);
    transition: all var(--transition-base, 0.2s ease);
    position: relative;
  }

  a:hover {
    color: var(--text-color, #333333);
    background-color: var(--hover-bg, rgba(0, 121, 107, 0.1));
  }

  a.active {
    color: var(--primary-color, #00796b);
    font-weight: 600;
  }

  a.active::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0.75rem;
    right: 0.75rem;
    height: 2px;
    background: var(--primary-gradient, linear-gradient(135deg, #00796b, #26a69a));
    border-radius: 2px;
    transform-origin: center;
    transform: scaleX(0.8);
    transition: transform 0.2s ease;
  }

  /* 为不同主题提供明确的颜色值 */
  [data-theme="light"] .nav-links a {
    color: #666666;
  }

  [data-theme="light"] a:hover {
    color: #333333;
    background-color: rgba(0, 121, 107, 0.1);
  }

  [data-theme="light"] a.active {
    color: #00796b;
  }

  [data-theme="light"] a.active::after {
    background: linear-gradient(135deg, #00796b, #26a69a);
  }

  [data-theme="dark"] .nav-links a {
    color: #cccccc;
  }

  [data-theme="dark"] a:hover {
    color: #ffffff;
    background-color: rgba(38, 166, 154, 0.2);
  }

  [data-theme="dark"] a.active {
    color: #26a69a;
  }

  [data-theme="dark"] a.active::after {
    background: linear-gradient(135deg, #26a69a, #4db6ac);
  }

  a.active:hover::after {
    transform: scaleX(1);
  }

  @media (max-width: 640px) {
    nav {
      padding: 1.5rem 1.5rem;
    }
    
    .nav-links {
      gap: 1rem;
    }
    
    a {
      font-size: var(--text-sm);
      padding: 0.4rem 0.6rem;
    }
  }
</style>
